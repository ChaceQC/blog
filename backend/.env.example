# 后端本地开发配置
BLOG_APP_NAME=Blog CMS API
BLOG_VERSION=0.1.0
BLOG_ENVIRONMENT=development
BLOG_DEBUG=false
BLOG_DOCS_ENABLED=true
BLOG_READINESS_CHECK_DATABASE=false

# 本地开发密钥仅用于开发环境
BLOG_SECRET_KEY=dev-only-change-me
BLOG_ACCESS_TOKEN_EXPIRE_MINUTES=15
BLOG_REFRESH_TOKEN_EXPIRE_DAYS=14
BLOG_ENCRYPTION_SESSION_EXPIRE_SECONDS=300
BLOG_ADMIN_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
BLOG_ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
BLOG_ENCRYPTION_SESSION_RATE_LIMIT_MAX_ATTEMPTS=120
BLOG_ENCRYPTION_SESSION_RATE_LIMIT_WINDOW_SECONDS=60
BLOG_ADMIN_ENCRYPTION_SESSION_ACTIVE_LIMIT_PER_IP=30
BLOG_PUBLIC_ENCRYPTION_SESSION_ACTIVE_LIMIT_PER_IP=60
BLOG_FRIEND_LINK_APPLICATION_RATE_LIMIT_MAX_ATTEMPTS=5
BLOG_FRIEND_LINK_APPLICATION_RATE_LIMIT_WINDOW_SECONDS=600
BLOG_POST_INTERACTION_RATE_LIMIT_MAX_ATTEMPTS=30
BLOG_POST_INTERACTION_RATE_LIMIT_WINDOW_SECONDS=60
BLOG_POST_VIEW_DEDUPE_SECONDS=600
BLOG_POST_LIKE_RISK_WINDOW_SECONDS=86400
BLOG_RATE_LIMIT_BACKEND=memory
BLOG_REDIS_URL=
BLOG_REDIS_KEY_PREFIX=blog:rate-limit
BLOG_TRUSTED_PROXY_HOSTS=[]
BLOG_ADMIN_COOKIE_SECURE=false
BLOG_ADMIN_COOKIE_SAMESITE=lax

# 本地开发端口避免使用 3000、5173、8000 等常见端口
BLOG_DEV_SERVER_HOST=127.0.0.1
BLOG_DEV_SERVER_PORT=18080
BLOG_PUBLIC_BASE_URL=http://127.0.0.1:15173
BLOG_ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]
BLOG_CORS_ORIGINS=["http://127.0.0.1:15173","http://localhost:15173"]

BLOG_DATABASE_URL=mysql+aiomysql://blog_app:blog_dev_password@127.0.0.1:3306/blog?charset=utf8mb4
BLOG_UPLOAD_ROOT=var/uploads
BLOG_UPLOAD_MAX_SIZE_BYTES=20971520
BLOG_FILE_TEMPORARY_URL_EXPIRE_SECONDS=300
BLOG_AVATAR_CACHE_TTL_SECONDS=3600
BLOG_AVATAR_CACHE_MAX_SIZE_BYTES=2097152
BLOG_AVATAR_CACHE_REQUEST_TIMEOUT_SECONDS=5
BLOG_AVATAR_CACHE_RETRY_ATTEMPTS=2
BLOG_ACCESS_LOG_DEDUPE_SECONDS=60
