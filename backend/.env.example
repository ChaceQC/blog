# 后端本地开发配置
BLOG_APP_NAME=Blog CMS API
BLOG_VERSION=0.1.0
BLOG_ENVIRONMENT=development
BLOG_DEBUG=false
BLOG_DOCS_ENABLED=true
BLOG_READINESS_CHECK_DATABASE=false

# 本地开发密钥仅用于开发环境
BLOG_SECRET_KEY=dev-only-change-me
BLOG_ACCESS_TOKEN_EXPIRE_MINUTES=15
BLOG_REFRESH_TOKEN_EXPIRE_DAYS=14

# 本地开发端口避免使用 3000、5173、8000 等常见端口
BLOG_DEV_SERVER_HOST=127.0.0.1
BLOG_DEV_SERVER_PORT=18080
BLOG_PUBLIC_BASE_URL=http://127.0.0.1:15173
BLOG_ALLOWED_HOSTS=["localhost","127.0.0.1","testserver"]
BLOG_CORS_ORIGINS=["http://127.0.0.1:15173","http://localhost:15173"]

BLOG_DATABASE_URL=mysql+asyncmy://blog_app:blog_dev_password@127.0.0.1:3306/blog?charset=utf8mb4
BLOG_UPLOAD_ROOT=var/uploads
