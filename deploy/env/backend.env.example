# 后端运行环境
BLOG_APP_NAME=Blog CMS API
BLOG_VERSION=0.1.0
BLOG_ENVIRONMENT=production
BLOG_DEBUG=false
BLOG_DOCS_ENABLED=false
BLOG_READINESS_CHECK_DATABASE=true

# 生产环境必须替换为 32 位以上强随机值
BLOG_SECRET_KEY=change-this-to-a-long-random-secret
BLOG_ACCESS_TOKEN_EXPIRE_MINUTES=15
BLOG_REFRESH_TOKEN_EXPIRE_DAYS=14
BLOG_ENCRYPTION_SESSION_EXPIRE_SECONDS=300
BLOG_ADMIN_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
BLOG_ADMIN_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
BLOG_ENCRYPTION_SESSION_RATE_LIMIT_MAX_ATTEMPTS=20
BLOG_ENCRYPTION_SESSION_RATE_LIMIT_WINDOW_SECONDS=60
BLOG_ADMIN_COOKIE_SECURE=true
BLOG_ADMIN_COOKIE_SAMESITE=lax

# 本地开发入口字段也通过环境变量提供，生产容器不会直接暴露该端口
BLOG_DEV_SERVER_HOST=127.0.0.1
BLOG_DEV_SERVER_PORT=18080

# 按真实域名调整
BLOG_PUBLIC_BASE_URL=https://example.com
BLOG_ALLOWED_HOSTS=["example.com"]
BLOG_CORS_ORIGINS=["https://example.com"]

# 密码需与 mysql.env 中的 MYSQL_PASSWORD 保持一致
BLOG_DATABASE_URL=mysql+asyncmy://blog_app:change-this-database-password@mysql:3306/blog?charset=utf8mb4
BLOG_UPLOAD_ROOT=/data/blog/uploads
